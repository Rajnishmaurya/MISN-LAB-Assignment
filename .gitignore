# =============================================================================
#  .gitignore — MISN Lab AdiVaani Assignment
#  Large files excluded from GitHub (GitHub hard limit: 100MB per file)
#  All excluded files can be reproduced using the provided scripts.
# =============================================================================

# ── Checkpoints (96MB–909MB each; reproduce with run_all.sh) ─────────────────
part1nmt/checkpoints/
part2/checkpoints/
*.pt
*.pth

# ── Downloaded pretrained BERT weights (906MB each; run download_models.py) ──
*.safetensors
*.bin

# ── Large training data (too large; download from assignment link) ────────────
part1nmt/data/train.hi
part1nmt/data/train.mr
part1nmt/data/train.src
part1nmt/data/train.tgt
part2/data/train.src
part2/data/train.tgt

# ── Large intermediate files (regenerated by pipeline scripts) ────────────────
part1nmt/final_combined.txt
part1nmt/combined.txt
part2/data/pretrain_corpus.txt

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editors / IDEs ────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
